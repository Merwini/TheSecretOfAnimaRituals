					<soundWounded>TSOA_KodamaWounded</soundWounded>
					<soundDeath>TSOA_KodamaDeath</soundDeath>
					<soundCall>TSOA_KodamaCall</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>body</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5</power>
