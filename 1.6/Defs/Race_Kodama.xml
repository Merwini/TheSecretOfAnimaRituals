			<ArmorRating_Blunt>0.0</ArmorRating_Blunt>
			<ArmorRating_Heat>0.0</ArmorRating_Heat>
			<CarryingCapacity>65.0</CarryingCapacity>
			<Mass>10.0</Mass>
			<VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1.0</VacuumResistance>
		</statBases>
		<race>
			<!-- TODO -->
			<intelligence>ToolUser</intelligence>
			<body>QuadrupedAnimalWithPawsAndTail</body>
			<baseBodySize>0.6</baseBodySize>
			<hasGenders>false</hasGenders>
			<bloodDef>Filth_Blood</bloodDef>
			<bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
			<lifeStageAges>
				<li>
					<!-- TODO -->
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<!-- TODO -->
					<soundWounded>Pawn_Mech_Constructoid_Wounded</soundWounded>
					<!-- TODO -->
					<soundDeath>Pawn_Mech_Constructoid_Death</soundDeath>
					<!-- TODO -->
					<soundCall>Pawn_Mech_Constructoid_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>torso</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>5</power>
				<cooldownTime>2.9</cooldownTime>
				<linkedBodyPartsGroup>Torso</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>

