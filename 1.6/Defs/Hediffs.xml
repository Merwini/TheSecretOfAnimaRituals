<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<HediffDef>
		<defName>TSOA_PsychicSevering</defName>
		<hediffClass>HediffWithComps</hediffClass>
		<label>psychic severing</label>
		<description>An intentional severing from all psychic attunement, essentially causing psychic deafness.</description>
		<isBad>false</isBad>
		<tendable>false</tendable>
		<alwaysShowSeverity>true</alwaysShowSeverity>
		<maxSeverity>1</maxSeverity>
		<stages>
			<li>
				<label>psychically severed</label>
				<statFactors>
					<PsychicSensitivity>0</PsychicSensitivity>
				</statFactors>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-0.17</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
		</comps>
	</HediffDef>

	<HediffDef Abstract="True" Name="TSOA_PsychicFeverBase">
		<hediffClass>HediffWithComps</hediffClass>
		<label>psychic fever</label>
		<description>A psychically-induced fever that supercharges immune response, but will cause the patient to die if not tended frequently. Leaves the patient dilirious and unable to medically care for themself or others.</description>
		<tendable>true</tendable>
		<isBad>true</isBad>
		<initialSeverity>0</initialSeverity>
		<lethalSeverity>1.0</lethalSeverity>
		<stages>
			<li>
				<statFactors>
					<ImmunityGainSpeed>2.0</ImmunityGainSpeed>
				</statFactors>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.5</setMax>
					</li>
				</capMods>
				<disabledWorkTags>
					<li>Caring</li>
				</disabledWorkTags>
			</li>
		</stages>
		<comps>
			<li Class="HediffCompProperties_TendDuration">
				<baseTendDurationHours>3</baseTendDurationHours>
				<tendOverlapHours>0.5</tendOverlapHours>
			</li>
		</comps>
	</HediffDef>

	<HediffDef ParentName="TSOA_PsychicFeverBase">
		<defName>TSOA_PsychicFever_Success</defName>
		<label>psychic fever</label>
		<comps>
			<li Class="tsoa.rituals.HediffCompProperties_PsychicFever">
				<hoursToLethal>6</hoursToLethal>
				<severityAfterTend>0</severityAfterTend>
				<durationDays>2</durationDays>
			</li>
		</comps>
	</HediffDef>

	<HediffDef ParentName="TSOA_PsychicFeverBase">
		<defName>TSOA_PsychicFever_Failure</defName>
		<label>psychic fever (unstable)</label>
		<comps>
			<li Class="tsoa.rituals.HediffCompProperties_PsychicFever">
				<hoursToLethal>6</hoursToLethal>
				<severityAfterTend>0</severityAfterTend>
				<durationDaysRandom>4~6</durationDaysRandom>
			</li>
		</comps>
	</HediffDef>

</Defs>